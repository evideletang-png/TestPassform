APP_NAME="PassForm"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://testpassform-production.up.railway.app
APP_TIMEZONE=Europe/Paris
APP_LOCALE=fr

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Base de données ────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=passform
DB_USERNAME=passform_user
DB_PASSWORD=CHANGEZ_MOI

# ── Cache & Sessions ───────────────────────────────────────────────────────────
# Utilisez 'database' si Redis n'est pas disponible sur votre VPS
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# ── File storage ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Mail (pour notifications éventuelles) ─────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.votre-hebergeur.fr
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@votre-domaine.fr"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sécurité RGPD ─────────────────────────────────────────────────────────────
# APP_KEY est utilisée pour chiffrer les NIR (AES-256-CBC via Encrypter Laravel)
# NE JAMAIS changer APP_KEY après mise en production (les NIR chiffrés seraient illisibles)
# Sauvegarder APP_KEY dans un gestionnaire de secrets

# ── Filament ──────────────────────────────────────────────────────────────────
FILAMENT_FILESYSTEM_DISK=public
